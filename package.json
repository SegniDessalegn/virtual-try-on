{
  "name": "virtual-try-on",
  "displayName": "Virtual try on",
  "version": "0.0.1",
  "description": "A simple mockup extension",
  "author": "Segni D. (segnides@gmail.com)",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@plasmohq/storage": "^1.15.0",
    "lucide-react": "^1.8.0",
    "luxon": "^3.7.2",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "sidePanel",
      "storage"
    ],
    "host_permissions": [
      "https://*/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  }
}
